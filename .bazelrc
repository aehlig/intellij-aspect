build --@protobuf//bazel/toolchains:prefer_prebuilt_protoc

build --java_runtime_version=remotejdk_21 --java_language_version=21
build --tool_java_runtime_version=remotejdk_21 --tool_java_language_version=21

common --enable_platform_specific_config

# pass the host's MSYS2 installation through the test environment repository
build:windows --repo_env=BAZEL_SH

# avoid self-extracting Python zip launchers on Windows; their runfiles extraction can exceed MAX_PATH
build --@rules_python//python/config_settings:build_python_zip=false
build --enable_runfiles

# disallow network access by default to make sure our bazel caches work as intended
build --sandbox_default_allow_network=false

# configure the number of workers per bazel version (manged by the multiplex worker)
build --//testing/rules:max_servers=1

# workaround for rules_android issue since CI defines these environment variables
common --repo_env=ANDROID_HOME=""
common --repo_env=ANDROID_SDK_ROOT=""
common --repo_env=ANDROID_NDK_HOME=""
common --repo_env=ANDROID_NDK_ROOT=""

# User-specific .bazelrc
try-import %workspace%/user.bazelrc
